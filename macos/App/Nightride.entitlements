<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Minimal entitlements for the Developer-ID, notarized, Hardened-Runtime
         direct-download build. The App Sandbox is deliberately NOT used here
         (that is only for the Mac App Store build, see
         Nightride.appstore.entitlements); sandboxing would complicate the
         menu-bar / Now Playing / media-key integration for no benefit in a
         direct download.

         Hardened Runtime is enabled via the codesign runtime option in
         release.sh. Networking is outbound HTTP(S) to the stream and meta feed,
         which needs no special entitlement outside the sandbox, so this list is
         intentionally empty. Add JIT or dyld exceptions here only if a future
         dependency requires them. -->
</dict>
</plist>
